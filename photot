                        <span style="font-size: 11px; font-weight: 600; text-transform: uppercase; color: #475569; letter-spacing: 0.05em; display: block; margin-bottom: 8px;">
                            Registry Audit Data
                        </span>

                        <div style="font-family: monospace; font-size: 11px; color: #334155; line-height: 1.5;">
                            <div style="margin-bottom: 4px; border-bottom: 1px dashed #e2e8f0; padding-bottom: 4px;">
                                <span style="color: #64748b;">badge type:</span> 
                                <span style="font-weight: 600; float: right; text-transform: uppercase;">standard_employee_rfid</span>
                            </div>
                            <div style="margin-bottom: 4px; border-bottom: 1px dashed #e2e8f0; padding-bottom: 4px;">
                                <span style="color: #64748b;">security tier:</span> 
                                <span style="font-weight: 600; float: right;">level_1_access</span>
                            </div>
                            <div>
                                <span style="color: #64748b;">badge holder:</span> 
                                <span style="font-weight: 600; float: right; text-transform: uppercase;">{{ request.user.username }}</span>
                            </div>
                        </div>
                    </div>

                </div>
            </div> <!-- Closes #view-workflow -->

        </div> <!-- Closes .status-feed-container -->
    </section>

</div> <!-- Closes .portal-container -->

<!-- Vanilla JavaScript View Switcher Engine -->
<script>
    (function () {
    let currentScaleValue = 1.0;
    let currentRotationDegrees = 0;

    const previewImageElement = document.getElementById('imageLivePreview');
    const previewRow = document.getElementById('preview-row');
    const fileInput = document.getElementById('fileInputSelector');

    function applyCSSMatrixStyles() {
        previewImageElement.style.transform = 'scale(' + currentScaleValue + ') rotate(' + currentRotationDegrees + 'deg)';
    }

    window.handleFilePreview = function (input) {
        const file = input.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = function (e) {
            previewImageElement.src = e.target.result;
            previewRow.style.display = 'table-row';
            currentScaleValue = 1.0;
                        currentRotationDegrees = 0;
            applyCSSMatrixStyles();
        };
        reader.readAsDataURL(file);
    };

    window.adjustImageTransform = function (command) {
        if (command === 'zoom-in') {
            currentScaleValue += 0.08;
        } else if (command === 'zoom-out') {
            if (currentScaleValue > 0.5) currentScaleValue -= 0.08;
        } else if (command === 'rotate') {
            currentRotationDegrees += 90;
        } else if (command === 'reset') {
            fileInput.value = '';
            previewImageElement.src = '';
            previewRow.style.display = 'none';
            return;
        }
        applyCSSMatrixStyles();
    };

    window.switchRightTab = function(targetTab) {
        document.querySelectorAll('.tab-content-view').forEach(view => view.style.display = 'none');
        document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
        document.getElementById('view-' + targetTab).style.display = 'block';
        document.getElementById('tab-' + targetTab).classList.add('active');
    };
})();
function switchRightTab(targetTab) {
    // Hide all right sidebar panels
    document.querySelectorAll('.tab-content-view').forEach(view => {
        view.style.display = 'none';
    });
    
    // Clear active class states from header buttons
    document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.classList.remove('active');
    });

    // Activate and display targeted tab selection
    document.getElementById('view-' + targetTab).style.display = 'block';
    document.getElementById('tab-' + targetTab).classList.add('active');
}
function showUploadedImage() {
  const fileInput = document.getElementById("bloodUpload");
  const previewDiv = document.getElementById("uploadedImagePreview");
    // Clear previous preview and center the container
    previewDiv.innerHTML = "";
    previewDiv.style.textAlign = 'center';
    previewDiv.style.width = '100%';

    if (fileInput.files && fileInput.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
            const img = document.createElement("img");
            img.src = e.target.result;
            img.style.maxWidth = "150px";  // adjust size
            img.style.display = 'block';
            img.style.margin = '0 auto';
            img.style.border = "1px solid #ccc";
            img.style.borderRadius = "4px";
            previewDiv.appendChild(img);
        };
        reader.readAsDataURL(fileInput.files[0]);
    }
}



</script>
{% endblock %}


