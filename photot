                            <input type="checkbox" required style="width: 15px; height: 15px; margin-top: 2px; cursor: pointer;">
                            <span>I Accept that all information provided is correct to the best of my knowledge . I Understand that i used to upload my professional photograph only</span>
                        </label>
                    </div>

                    <div class="action-panel" style="justify-content: center; padding: 0;">
                        <button type="submit" class="btn-portal btn-portal-submit" style="padding: 8px 24px;">
                            Save
                        </button>
                        <button type="submit" class="btn-portal btn-portal-submit" style="padding: 8px 24px;">
                            Submit
