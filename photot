            <button type="button" class="btn-portal" style="min-width: auto; padding: 2px 8px; font-size: 12px;" onclick="adjustImageTransform('zoom-out')">-</button>
            <button type="button" class="btn-portal" style="min-width: auto; padding: 2px 8px; font-size: 12px;" onclick="adjustImageTransform('rotate')">⟳</button>
            <button type="button" class="btn-portal" style="min-width: auto; padding: 2px 8px; font-size: 12px; color: #b91c1c; border-color: #fca5a5;" onclick="adjustImageTransform('reset')">Clear</button>
        </div>
    </td>
</tr>

        <tr>
            <td class="label-cell">Employee ID</td>
            <td class="input-cell" style="font-weight: 600; color: #1e3a8a;">{{ request.user.id|default:"EMP001" }}</td>
        </tr>
        <tr>
            <td class="label-cell">Request Type</td>
            <td class="input-cell" style="font-weight: 600; color: #1e3a8a;">{{ request.user.request_type|default:"none" }}</td>
        </tr>
        <tr>
                        <td class="label-cell"><span class="required-star">*</span>Upload Id Card Image </td>
                        <td class="input-cell">
                            <input type="file" id="fileInputSelector" name="profile_photo" accept=".jpg,.jpeg,.png" required class="flat-input" onchange="handleFilePreview(this)">
                        </td>
                    </tr>
                   
        
       
    </tbody>
</table>


             <!-- <div class="form-group full-width" style="margin-top:15px;">
                    <label class="checkbox-label-wrap" style="line-height:1.5;">
                        <input type="checkbox" name="consent_checkbox" required>
                        <span>I Accept that all information provided is correct to the best of my knowledge . I Understand that i used to upload my professional photograph only</span>
                    </label>
                </div> -->

            {% if request_status == "Not Requested" %}
                <form method="POST" action="/personal-information/id-card-workspace/" style="margin: 0; padding: 0 12px;">
                    {% csrf_token %}
                    <div style="background-color: #fff; border: 1px solid #cbd5e1; border-radius: 4px; padding: 12px; margin-bottom: 16px;">
