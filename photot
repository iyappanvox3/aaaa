            <button type="button" class="tab-btn-existing active" id="tab-existing" onclick="switchRightTab('existing')">Existing</button>
            <button type="button" class="tab-btn-help" id="tab-help" onclick="switchRightTab('help')">Help</button>
            <button type="button" class="tab-btn-status tab-btn-header-purple" id="tab-workflow" onclick="switchRightTab('workflow')">Approval Flow/Status</button>
        </div>

        <div class="status-feed-container">
            
            
