                        {% endif %}
                    </div>
                    <div class="data-row">
                        <span>Employee Name:</span>
                        <span class="data-val">{{ request.user.username }}</span>
                    </div>
                    <div class="data-row">
                        <span>Office Worksite:</span>
                        <span class="data-val">{{ request.user.personal_details.addresses.office_worksite|default:"Voxlom" }}</span>
                    </div>
                </div>
