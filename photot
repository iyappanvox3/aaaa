    <!-- Left Navigation Sidebar -->
    

    <!-- Center Module Area: Data Verification Sheet & Form Dispatch -->
    <main class="portal-workspace">
        <div class="workspace-header">ID Card Request </div>
        
        <!-- Django Messaging Notification Alerts -->
        {% if messages %}
            {% for message in messages %}
                <div style="background-color: #eff6ff; color: #1e40af; padding: 10px; font-size: 13px; border-bottom: 1px solid #bfdbfe;" role="alert">
                    {{ message }}
                </div>
            {% endfor %}
        {% endif %}

        <div style="padding: 16px; margin: 0; flex: 1; background-color: #ffffff;">
                     <table class="form-grid-table" style="width: 100%; border-collapse: collapse; margin-bottom: 16px;">
    <tbody>
        <tr>
            <td class="label-cell">Full Name</td>
            <td class="input-cell" style="font-weight: 600; color: #0f172a;">{{ request.user.username }}</td>
        </tr>
         <tr id="preview-row" style="display: none;">
    <td class="label-cell"></td>
    <!-- Added padding-left to shift the internal components completely to the right -->
    <td class="input-cell" style="padding-left: 450px !important;">
        <!-- Matrix Manipulation Frame Box View Container -->
        <div style="width: 140px; height: 140px; border: 1px solid #cbd5e1; border-radius: 4px; overflow: hidden; display: flex; align-items: center; justify-content: center; background: #f8fafc; margin-bottom: 8px;">
