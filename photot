{% extends "base.html" %}
{% block extra_css %}
{% include "personal_information/_pi_theme.html" %}
<style>
    /* Global layout container mimicking the reference layout */
    .portal-container {
        display: flex;
        font-family: Arial, sans-serif;
        font-size: 13px;
        background-color: #f3f4f6;
        min-height: 100vh;
    }

    /* Left Sidebar Styling */
    .portal-sidebar {
        width: 220px;
        background-color: #e9d5ff; /* Light purple menu stack background */
        border-right: 1px solid #d8b4fe;
        flex-shrink: 0;
    }
    .sidebar-section-header {
        background-color: #c084fc;
        color: #000;
        font-weight: bold;
        padding: 8px 12px;
        border-bottom: 1px solid #a855f7;
    }
    .sidebar-menu {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .sidebar-menu li a {
        display: block;
        padding: 6px 12px;
        color: #000;
        text-decoration: none;
        border-bottom: 1px solid #e2e8f0;
    }
    .sidebar-menu li.active a {
        background-color: #a855f7;
        color: #ffffff;
        font-weight: bold;
    }

    /* Central Workspace Panel */
    .portal-workspace {
        flex: 1;
        background-color: #ffffff;
        border-right: 1px solid #cbd5e1;
        display: flex;
        flex-direction: column;
    }
    .workspace-header {
        background-color: var(--form-heading);
        color: #ffffff;
        font-weight: bold;
        font-size: 15px;
        text-align: center;
        padding: 8px;
        text-transform: uppercase;
        border-bottom: 1px solid #cbd5e1;
    }
     tbody td,label,option {
     font-family: 'Poppins', sans-serif
}

    /* Structured Field Layout */
    .form-grid-table {
        width: 100%;
        border-collapse: collapse;
    }
    .form-grid-table td {
        border-bottom: 1px solid #e2e8f0;
        padding: 6px 12px;
        vertical-align: middle;
    }
    /* Utility cell-centering class for specific rows */
    .form-grid-table td.center {
        text-align: center;
    }
    /* Center the right-side/input column cells */
    
    .label-cell {
        width: 35%;
        text-align: right;
        font-weight: normal;
        color: #334155;
        background-color: #ffffff;
        padding-right: 15px !important;
    }
    .required-star {
        color: #dc2626;
        margin-right: 2px;
    }
    .input-cell {
        width: 65%;
    }
    .flat-input, .flat-select {
        width: 250px;
        padding: 4px 6px;
        border: 1px solid #94a3b8;
        border-radius: 3px;
        font-size: 13px;
        background-color: #ffffff;
    }
    .flat-input[type="file"] {
        border: none;
        padding: 0;
        background: transparent;
    }

    /* Form control action panel at footer */
    .action-panel {
        display: flex;
        justify-content: center;
        gap: 10px;
        padding: 15px;
        background-color: #ffffff;
    }
    .btn-portal {
        min-width: 80px;
        padding: 6px 16px;
        font-size: 13px;
        border: 1px solid var(--form-submit);
        border-radius: 4px;
        cursor: pointer;
        background-color: #ffffff;
        color: #000000;
    }
    .btn-portal-submit {
        background-color: var(--form-submit);
        color: #ffffff;
    }

    /* Right Split Area: Action triggers and Read-only Verification Feed */
    .portal-status-pane {
        width: 300px;
        background-color: #f8fafc;
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
    }
    .status-top-bar {
        display: flex;
        border-bottom: 1px solid #cbd5e1;
    }
    .tab-btn {
        flex: 1;
        padding: 8px;
        font-size: 12px;
        border: none;
        background-color: #f1f5f9;
        border-right: 1px solid #cbd5e1;
        cursor: pointer;
        text-align: center;
    }
    .tab-btn.active {
        background-color: #ffffff;
        font-weight: bold;
    }
    .tab-btn-header-purple {
        background-color: var(--form-heading);
        font-weight: bold;
    }

    /* Right column record tracker stack */
    .status-feed-container {
        padding: 12px;
        overflow-y: auto;
    }
    .status-card {
        background: #ffffff;
        border: 1px solid #cbd5e1;
        border-radius: 4px;
        padding: 10px;
        margin-bottom: 10px;
    }
    .status-card-header {
        display: flex;
        justify-content: space-between;
        font-weight: bold;
        border-bottom: 1px solid #f1f5f9;
        padding-bottom: 4px;
        margin-bottom: 6px;
    }
    .data-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 4px;
        font-size: 12px;
    }
    .data-val {
        font-weight: bold;
        color: #1e293b;
    }
    .label-cells {
        margin-left: 0;
    }
</style>
{% endblock %}

{% block content %}
