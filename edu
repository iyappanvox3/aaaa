    <script>
        // Show selected file name feedback when a file is selected
        document.querySelectorAll('input[type="file"]').forEach(function (input) {
            input.addEventListener('change', function () {
                if (this.files && this.files.length > 0) {
                    var fileName = this.files[0].name;
                    var container = this.closest('div');
                    var existingBadge = container.querySelector('.selected-file-badge');
                    if (existingBadge) {
                        existingBadge.textContent = "Selected: " + fileName;
                    } else {
                        var badge = document.createElement('span');
                        badge.className = 'selected-file-badge';
                        badge.style.cssText = 'color: #2563eb; font-size: 11px; margin-top: 4px; display: inline-block; max-width: 120px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;';
                        badge.textContent = "Selected: " + fileName;
                        container.appendChild(badge);
                    }
                }
            });
        });
