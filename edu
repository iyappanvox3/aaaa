                        <span class="data-val"
                            style="max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"
                            title="{{ latest_record.details }}">{{ latest_record.details }}</span>
                    </div>

                    <div class="data-row">
                        <span>Completed:</span>
                        <span class="data-val">{{ latest_record.end_date }}</span>
                    </div>

                    <!-- Approval Flow Tracking Timeline Section -->
                    <div style="margin-top: 12px; border-top: 1px dashed #cbd5e1; padding-top: 10px;">
                        <span
                            style="font-size: 11px; font-weight: 600; text-transform: uppercase; color: #64748b; letter-spacing: 0.05em; display: block; margin-bottom: 6px;">
                            Approval Progress
                        </span>

                        <!-- Timeline Step 1 -->
                        <div style="display: flex; gap: 8px; font-size: 12px; margin-bottom: 6px;">
                            <div style="color: #166534; font-weight: bold;">✓</div>
                            <div style="flex: 1;">
                                <div style="font-weight: 600; color: #334155;">Record Registered</div>
                                <div style="font-size: 11px; color: #64748b;">Credentials uploaded to background file
                                </div>
                            </div>
                        </div>

                        <!-- Timeline Step 2 -->
                        <div style="display: flex; gap: 8px; font-size: 12px;">
                            <div style="color: #94a3b8; font-weight: bold;">○</div>
                            <div style="flex: 1;">
                                <div style="font-weight: 600; color: #94a3b8;">Background Verification</div>
                                <div style="font-size: 11px; color: #94a3b8;">Pending institutional credential match
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Read-only Reference Verification Feed -->
                    <div
                        style="margin-top: 14px; border-top: 1px solid #e2e8f0; padding-top: 12px; background-color: #f8fafc; border-radius: 4px; padding: 8px;">
                        <span
                            style="font-size: 11px; font-weight: 600; text-transform: uppercase; color: #475569; letter-spacing: 0.05em; display: block; margin-bottom: 8px;">
                            Registry Audit Data
                        </span>

                        <div style="font-family: monospace; font-size: 11px; color: #334155; line-height: 1.5;">
                            <div style="margin-bottom: 4px; border-bottom: 1px dashed #e2e8f0; padding-bottom: 4px;">
                                <span style="color: #64748b;">CREDENTIAL:</span>
                                <span style="font-weight: 600; float: right; text-transform: uppercase;">{{
                                    latest_record.subtype }}</span>
                            </div>
                            <div style="margin-bottom: 4px; border-bottom: 1px dashed #e2e8f0; padding-bottom: 4px;">
                                <span style="color: #64748b;">DURATION:</span>
                                <span style="font-weight: 600; float: right;">{{ latest_record.begin_date }} / {{
                                    latest_record.end_date }}</span>
                            </div>
                            <div>
                                <span style="color: #64748b;">DECLARED BY:</span>
                                <span style="font-weight: 600; float: right; text-transform: uppercase;">{{
                                    identity_demographics.first_name }} {{ identity_demographics.last_name }}</span>
                            </div>
                        </div>
                    </div>

                </div>
                {% endwith %}
                {% else %}
                <p style="color: #64748b; text-align: center; margin-top: 20px;">No registered metrics tracking
                    workflow.</p>
                {% endif %}
            </div> <!-- Closes #view-workflow -->

        </div> <!-- Closes .status-feed-container -->
    </section>

</div> <!-- Closes .portal-container -->

<!-- Vanilla JavaScript View Switcher Engine -->
<script>
    function switchRightTab(targetTab) {
        // Hide all right sidebar panels
        document.querySelectorAll('.tab-content-view').forEach(view => {
            view.style.display = 'none';
        });

        // Clear active class states from header buttons
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.classList.remove('active');
        });

        // Activate and display targeted tab selection
        document.getElementById('view-' + targetTab).style.display = 'block';
        document.getElementById('tab-' + targetTab).classList.add('active');
    }

