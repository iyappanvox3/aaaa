<script>
    window.isMenuCollapsed = true;

    function executeGridSearch() {
        const searchInput = document.getElementById('dashboardSearchInput');
        const searchVal = searchInput ? searchInput.value.toLowerCase().trim() : '';
        const categoryElement = document.getElementById('selected-category');
        const selectedCat = categoryElement ? categoryElement.textContent.trim().toLowerCase() : 'all';
        const dropdown = document.getElementById('search-results-dropdown');

        if (dropdown) {
            dropdown.innerHTML = '';
        }

        const targetCards = document.querySelectorAll('.apps-grid-menu .grid-item-link');
        let matchesCount = 0;
        const hasActiveFilter = searchVal !== '' || selectedCat !== 'all';

        targetCards.forEach(card => {
            if (card.id === 'btn-view-all' || card.id === 'btn-view-less') {
                return;
            }

            const cardCat = (card.getAttribute('data-category') || '').toLowerCase();
            const textLabel = card.querySelector('.grid-item-label');
            if (!textLabel) return;

            const cleanText = (textLabel.textContent || textLabel.innerText).trim();
            const textLower = cleanText.toLowerCase();

            const matchesText = searchVal === '' || textLower.indexOf(searchVal) > -1 || cardCat.indexOf(searchVal) > -1;

            let matchesCategory = false;
            if (selectedCat === 'all') {
                matchesCategory = true;
            } else {
                const categories = cardCat.split(/\s+/);
                matchesCategory = categories.includes(selectedCat);
            }

            const isCollapsible = card.classList.contains('collapsible-icon');
            let shouldDisplayInGrid = false;

            if (matchesText && matchesCategory) {
                if (hasActiveFilter) {
                    shouldDisplayInGrid = true;
                } else {
                    shouldDisplayInGrid = !(isCollapsible && window.isMenuCollapsed);
                }
            }

            if (shouldDisplayInGrid) {
                card.style.display = 'flex';
            } else {
                card.style.display = 'none';
            }

            if (matchesText && matchesCategory && searchVal !== '') {
                matchesCount++;
                const iconWrapper = card.querySelector('.icon-wrapper');
                const iconHTML = iconWrapper ? iconWrapper.innerHTML : '<i class="fa-solid fa-link"></i>';
                const iconClassList = iconWrapper ? iconWrapper.className : 'icon-wrapper';

                const itemElement = document.createElement('a');
                itemElement.href = card.getAttribute('href');
                itemElement.className = 'search-result-item';
                itemElement.innerHTML = `
                    <div class="${iconClassList}" style="position: static; transform: none; width: 28px; height: 28px; border-radius: 6px; font-size: 13px; box-shadow: none; display: flex; align-items: center; justify-content: center;">
                        ${iconHTML}
                    </div>
                    <span style="font-size: 13.5px; font-weight: 600; color: #475569;">${cleanText}</span>
                `;
                if (dropdown) {
                    dropdown.appendChild(itemElement);
                }
            }
        });

        const viewAllBtn = document.getElementById('btn-view-all');
        const viewLessBtn = document.getElementById('btn-view-less');
        if (viewAllBtn && viewLessBtn) {
            if (hasActiveFilter) {
                viewAllBtn.style.display = 'none';
                viewLessBtn.style.display = 'none';
            } else {
                if (window.isMenuCollapsed) {
                    viewAllBtn.style.display = 'flex';
                    viewLessBtn.style.display = 'none';
                } else {
                    viewAllBtn.style.display = 'none';
                    viewLessBtn.style.display = 'flex';
                }
            }
        }

        if (dropdown) {
            if (matchesCount > 0 && searchVal !== '') {
                dropdown.style.display = 'block';
            } else {
                dropdown.style.display = 'none';
            }
        }
    }

    function toggleCategoryMenu(event) {
        if (event) event.stopPropagation();
        const menu = document.getElementById('category-options-menu');
        if (menu) {
            menu.style.display = (menu.style.display === 'block') ? 'none' : 'block';
        }
    }

    function selectSearchCategory(category, event) {
        if (event) event.stopPropagation();
        const categoryElement = document.getElementById('selected-category');
        if (categoryElement) {
            categoryElement.textContent = category;
        }
        const menu = document.getElementById('category-options-menu');
        if (menu) {
            menu.style.display = 'none';
        }
        executeGridSearch();
    }

    document.addEventListener('click', function (event) {
        const categoryDropdown = document.querySelector('.search-category-dropdown');
        const categoryMenu = document.getElementById('category-options-menu');
        const searchDropdown = document.getElementById('search-results-dropdown');
        const searchWrapper = document.querySelector('.dropdown-search-container');

        if (categoryDropdown && !categoryDropdown.contains(event.target)) {
            if (categoryMenu) categoryMenu.style.display = 'none';
        }

        if (searchWrapper && !searchWrapper.contains(event.target)) {
            if (searchDropdown) searchDropdown.style.display = 'none';
        }
    });

    function ShowIcons(event) {
        if (event) event.preventDefault();
        window.isMenuCollapsed = false;
        executeGridSearch();
    }

    function HideIcons(event) {
        if (event) event.preventDefault();
        window.isMenuCollapsed = true;
        executeGridSearch();
    }
</script>
