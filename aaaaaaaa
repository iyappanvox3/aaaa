<style>
    html,
    body {
        margin: 0 !important;
        padding: 0 !important;
        width: 100% !important;
        overflow-x: hidden;
    }

    /* Styles the video to act as a full-size background canvas layer */
    .background-video {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 1;
        pointer-events: none;
    }



    .nav-bar,
    .dashboard-wrapper,
    .main-container {
        width: 100% !important;
        max-width: 100% !important;
        margin-left: 0 !important;
        margin-right: 0 !important;
        padding-left: 0;
        padding-right: 0;
    }

    .nav-bar {
        margin-left: 0 !important;
        margin-right: 0 !important;
    }

    .dashboard-wrapper {
        width: 100%;
        padding: 0;

        font-family: 'Plus Jakarta Sans', sans-serif;
        box-sizing: border-box;
        background: transparent;
        min-height: calc(100vh - 70px);
        display: flex;
        flex-direction: column;
    }

    .dashboard-wrapper * {
        box-sizing: border-box;
    }


    .glass-dashboard-card-full {
        background: #ffffff;
        width: 100%;
        border-radius: 20px;
        box-shadow: 0 10px 25px -5px rgba(15, 23, 42, 0.04), 0 8px 16px -6px rgba(15, 23, 42, 0.04);

        overflow: visible !important;
        display: flex;
        flex-direction: column;
        position: relative;
        flex-grow: 1;
        margin-top: 0 !important;
    }

    /* .nav-container {
        background-color: #e25555 !;
    } */


    .banner-header {
        background-image: url('/static/images/dash2.jpg');
        background-size: cover;
        background-position: center center;
        background-repeat: no-repeat;
        padding: 60px 20px 84px 20px;
        /* Enhanced baseline cushion room to balanced negative pulls */
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 24px;
        width: 100%;
        height: 320px;
        /* Ensures the banner content layers above the video background */
        position: relative;
        /* Establishes a new stacking context for the banner content */
        overflow: visible !important;
    }

    /* Translucent Opaque Floating Search Bar */
    .search-bar-container {
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.08);
        width: 100%;
        max-width: 380px;
        padding: 10px 18px;
        border-radius: 50px;
        display: flex;
        align-items: center;
        gap: 12px;
        backdrop-filter: blur(12px);
        transition: background-color 0.2s;
    }

    .search-bar-container:focus-within {
        background: rgba(255, 255, 255, 0.18);
    }

    .search-icon {
        font-size: 13px;
        opacity: 0.7;
        color: white;
    }

    .search-input {
        background: transparent;
        border: none;
        outline: none;
        width: 100%;
        color: white;
        font-size: 13px;
    }

    /* Custom Cursive Script Welcome Typography Style */
    .signature {
        font-family: "Love Light", cursive;
        font-size: 100px;
        /* You can make it slightly larger or smaller depending on the font */
        font-weight: 400;
        color: #ffffff;
        margin: 0;
        text-shadow: 0 2px 12px rgba(0, 0, 0, 0.15);
        display: inline-block;
        /* Required for the transform rotation to calculate properly */
        transform: rotate(-15deg);
    }

    .welcome-text {

        padding-bottom: 20px;
        display: inline-block;
        z-index: 2;
        /* Required for the transform rotation to calculate properly */
    }



    .apps-grid-menu {
        display: none !important;
    }

    .nav-links a {
        padding-right: 40px;
        font-family: "Cinzel", serif;

        text-decoration: none;
        color: #4169E1;
        font-weight: 1000 !important;
        font-size: 16px !important;
    }

    /* Navigation Link Box Wrappers */
    .grid-item-link {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 14px;
        text-decoration: none;
        width: 100%;
        max-width: 120px;
        transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        padding-top: 42px;

        /* 📐 INCREASES THE BOTTOM EXPORT ROOM BELOW THE TEXT LABELS */
        padding-bottom: 24px;
        /* Increase this value (e.g., 32px, 40px) if you need more space */
    }

    .brand-name {
        font-family: "Cinzel", serif;
        font-size: 37px;
        margin-left: 20px;
        font-weight: 700 !important;
    }

    .grid-item-link:hover {
        transform: translateY(-5px);
    }

    /* Rounded Geometric Icon Bubble Elements with Absolute Boundary Interception Positioning */
    /* UPDATED: Modern Floating Squircle Container Styles */
    .icon-wrapper {
        width: 64px;
        height: 64px;

        /* THE SQUIRCLE SECRET: Changes it from a perfect circle to a smooth rounded square */
        border-radius: 16px;

        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid transparent;
        box-shadow: 0 4px 10px -2px rgba(15, 23, 42, 0.05);
        background-color: #ffffff;

        /* Ensures any background color changes or shadow growth animations fluidly glide */
        transition: box-shadow 0.25s cubic-bezier(0.4, 0, 0.2, 1),
            background-color 0.25s cubic-bezier(0.4, 0, 0.2, 1),
            border-color 0.25s cubic-bezier(0.4, 0, 0.2, 1),
            transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);

        /* Keeps your existing center threshold line overlay layout intact */
        position: absolute;
        top: 0;
        transform: translateY(-50%);
        z-index: 10;

    }

    .icon-wrapper i {
        transition: color 0.3s ease, transform 0.3s ease;
    }

    .icon-wrapper svg {
        width: 26px;
        height: 26px;
    }

    /* Elegant Pop-Up Lift Animation on Mouse Hover */
    .grid-item-link:hover .icon-wrapper {
        /* Drops a soft, deep realistic floating drop shadow underneath the squircle card block */
        box-shadow: 0 20px 25px -5px rgba(15, 23, 42, 0.1), 0 10px 10px -5px rgba(15, 23, 42, 0.04);

        /* Lifts the button slightly higher and scales it up 5% for a premium responsive feel */
        transform: translateY(-55%) scale(1.05);
    }

    /* .nav-bar {
        display: flex;
        justify-content: space-between;
    } */


    .grid-item-link:hover .icon-wrapper {
        box-shadow: 0 12px 24px -6px rgba(15, 23, 42, 0.15);
